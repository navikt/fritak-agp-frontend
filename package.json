{
  "name": "fritak-agp-frontend",
  "version": "1.0.28",
  "private": true,
  "homepage": "/fritak-agp",
  "proxy": "http://localhost:8080",
  "type": "module",
  "scripts": {
    "dev": "vite  --host",
    "start": "vite",
    "start:host": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "lint": "eslint src/**/*.ts*",
    "lint:fix": "eslint src/**/*.ts* --fix",
    "prepare": "husky",
    "postinstall": "cross-os postinstall",
    "test:int": "playwright test",
    "test:watch": "vitest",
    "knip": "knip --no-exit-code --reporter json"
  },
  "cross-os": {
    "postinstall": {
      "darwin": "mkdir -p ./node_modules && touch ./node_modules/.metadata_never_index"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "engineStrict": true,
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.2.4",
    "@grafana/faro-web-tracing": "^2.2.4",
    "@navikt/aksel-icons": "^8.6.0",
    "@navikt/ds-css": "^8.6.0",
    "@navikt/ds-react": "^8.6.0",
    "@navikt/fnrvalidator": "^2.2.1",
    "@navikt/nav-dekoratoren-moduler": "^3.6.2",
    "@navikt/textparser": "^2.4.0",
    "@navikt/virksomhetsvelger": "^1.0.7",
    "csp-header": "^6.3.0",
    "date-fns": "^4.1.0",
    "html-react-parser": "^5.2.17",
    "i18next": "^25.8.13",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^10.0.1",
    "@navikt/aksel": "^8.6.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "3.x",
    "@types/node": "24.x",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "cross-os": "1.5.0",
    "eslint": "^10.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "9.x",
    "jest-axe": "10.x",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "mockdate": "^3.0.5",
    "msw": "^2.12.10",
    "prettier": "3.x",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.97.3",
    "timezone-mock": "1.x",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "vitest-sonar-reporter": "^3.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
